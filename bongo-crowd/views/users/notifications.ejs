<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | BongoCrowd</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #0f0f1a;
      color: #e6e6ff;
      min-height: 100vh;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    /* Header */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .page-title {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #a855f7 0%, #06b6d4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .unread-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: rgba(168, 85, 247, 0.15);
      border: 1px solid rgba(168, 85, 247, 0.3);
      border-radius: 20px;
      font-size: 0.85rem;
      color: #a855f7;
      font-weight: 500;
    }

    .unread-dot {
      width: 8px;
      height: 8px;
      background: #a855f7;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.9); }
    }

    .mark-all-btn {
      padding: 10px 20px;
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.3);
      border-radius: 8px;
      color: #06b6d4;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .mark-all-btn:hover {
      background: rgba(6, 182, 212, 0.2);
      border-color: #06b6d4;
      transform: translateY(-2px);
    }

    /* Notifications List */
    .notifications-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .notification-item {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      padding: 20px 24px;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
      text-decoration: none;
      color: inherit;
    }

    .notification-item:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(168, 85, 247, 0.25);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(168, 85, 247, 0.1);
    }

    .notification-item.unread {
      background: rgba(168, 85, 247, 0.05);
      border-left: 3px solid #a855f7;
    }

    .notification-item.unread:hover {
      background: rgba(168, 85, 247, 0.08);
    }

    /* Notification Icon */
    .notification-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.1rem;
    }

    .notification-icon.report_update {
      background: rgba(6, 182, 212, 0.15);
      color: #06b6d4;
    }

    .notification-icon.bounty_received {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
    }

    .notification-icon.mention {
      background: rgba(168, 85, 247, 0.15);
      color: #a855f7;
    }

    .notification-icon.program_invite {
      background: rgba(245, 158, 11, 0.15);
      color: #f59e0b;
    }

    /* Notification Content */
    .notification-content {
      flex: 1;
      min-width: 0;
    }

    .notification-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: #ffffff;
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .notification-message {
      font-size: 0.9rem;
      color: #a0a0c0;
      line-height: 1.5;
    }

    .notification-time {
      font-size: 0.8rem;
      color: #6b7280;
      margin-top: 6px;
    }

    /* Unread Indicator */
    .unread-indicator {
      width: 10px;
      height: 10px;
      background: linear-gradient(135deg, #a855f7 0%, #06b6d4 100%);
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 6px;
      box-shadow: 0 0 10px rgba(168, 85, 247, 0.5);
    }

    /* Mark as Read Button */
    .mark-read-btn {
      padding: 6px 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      color: #6b7280;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s ease;
      opacity: 0;
      white-space: nowrap;
    }

    .notification-item:hover .mark-read-btn {
      opacity: 1;
    }

    .mark-read-btn:hover {
      background: rgba(6, 182, 212, 0.15);
      border-color: #06b6d4;
      color: #06b6d4;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
      background: rgba(255, 255, 255, 0.02);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
    }

    .empty-icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 24px;
      background: rgba(168, 85, 247, 0.1);
      border: 1px solid rgba(168, 85, 247, 0.2);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
    }

    .empty-title {
      font-size: 1.4rem;
      font-weight: 600;
      color: #ffffff;
      margin-bottom: 8px;
    }

    .empty-text {
      color: #6b7280;
      font-size: 0.95rem;
      max-width: 400px;
      margin: 0 auto;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }

      .notification-item {
        padding: 16px;
      }

      .notification-icon {
        width: 40px;
        height: 40px;
        font-size: 1rem;
      }

      .mark-read-btn {
        opacity: 1;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="page-header">
      <div>
        <h1 class="page-title">Notifications</h1>
      </div>
      <div style="display: flex; align-items: center; gap: 12px;">
        <% const unreadCount = notifications.filter(n => !n.is_read).length; %>
        <% if (unreadCount > 0) { %>
          <span class="unread-badge">
            <span class="unread-dot"></span>
            <%= unreadCount %> unread
          </span>
        <% } %>
        <% if (notifications.length > 0) { %>
          <form action="/users/notifications/mark-all-read" method="POST" style="display: inline;">
            <button type="submit" class="mark-all-btn">Mark all as read</button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Notifications List -->
    <% if (notifications.length === 0) { %>
      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <h2 class="empty-title">No notifications yet</h2>
        <p class="empty-text">You're all caught up! We'll notify you when there are updates on your reports, bounties, or mentions.</p>
      </div>
    <% } else { %>
      <div class="notifications-list">
        <% notifications.forEach(notification => { %>
          <div class="notification-item <%= !notification.is_read ? 'unread' : '' %>" data-id="<%= notification.id %>">
            <!-- Icon based on type -->
            <div class="notification-icon <%= notification.type %>">
              <% if (notification.type === 'report_update') { %>
                📋
              <% } else if (notification.type === 'bounty_received') { %>
                💰
              <% } else if (notification.type === 'mention') { %>
                💬
              <% } else if (notification.type === 'program_invite') { %>
                ✉️
              <% } else { %>
                🔔
              <% } %>
            </div>

            <!-- Content -->
            <a href="<%= notification.link || '#' %>" class="notification-content" style="text-decoration: none; color: inherit; display: block;">
              <div class="notification-title">
                <%= notification.title %>
                <% if (!notification.is_read) { %>
                  <span class="unread-indicator"></span>
                <% } %>
              </div>
              <div class="notification-message"><%= notification.message %></div>
              <div class="notification-time">
                <%= new Date(notification.created_at).toLocaleDateString('en-US', { 
                  month: 'short', 
                  day: 'numeric',
                  year: new Date(notification.created_at).getFullYear() !== new Date().getFullYear() ? 'numeric' : undefined
                }) %> • 
                <%= (() => {
                  const now = new Date();
                  const created = new Date(notification.created_at);
                  const diffMs = now - created;
                  const diffMins = Math.floor(diffMs / 60000);
                  const diffHours = Math.floor(diffMs / 3600000);
                  const diffDays = Math.floor(diffMs / 86400000);
                  
                  if (diffMins < 1) return 'just now';
                  if (diffMins < 60) return `${diffMins}m ago`;
                  if (diffHours < 24) return `${diffHours}h ago`;
                  if (diffDays < 7) return `${diffDays}d ago`;
                  if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
                  return `${Math.floor(diffDays / 30)}mo ago`;
                })() %>
              </div>
            </a>

            <!-- Mark as read button -->
            <% if (!notification.is_read) { %>
              <form action="/users/notifications/<%= notification.id %>/mark-read" method="POST" style="display: inline;">
                <button type="submit" class="mark-read-btn" onclick="event.stopPropagation();">
                  Mark read
                </button>
              </form>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <script>
    // Handle notification item clicks
    document.querySelectorAll('.notification-item').forEach(item => {
      item.addEventListener('click', function(e) {
        // Don't navigate if clicking the mark as read button
        if (e.target.closest('.mark-read-btn')) return;
        
        const link = this.querySelector('.notification-content');
        if (link && link.href && link.href !== '#') {
          window.location.href = link.href;
        }
      });
    });
  </script>
</body>
</html>
