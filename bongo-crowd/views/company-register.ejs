<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | BONGO-CROWD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .register-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
        }
        
        .register-card {
            width: 100%;
            max-width: 600px;
            background: rgba(21, 21, 32, 0.95);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 16px;
            padding: 2.5rem;
        }
        
        .register-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .register-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }
        
        .register-header p {
            color: #71717a;
        }
        
        .form-group {
            margin-bottom: 1.25rem;
        }
        
        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            color: #e4e4e7;
            font-weight: 500;
            font-size: 0.9rem;
        }
        
        .form-label .required {
            color: #ef4444;
        }
        
        .form-input, .form-textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            background: rgba(9, 9, 11, 0.5);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 8px;
            color: #e4e4e7;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .form-input:focus, .form-textarea:focus {
            outline: none;
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
        }
        
        .form-textarea {
            min-height: 100px;
            resize: vertical;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        
        .btn-submit {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }
        
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
        }
        
        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #ef4444;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }
        
        .alert-error ul {
            margin: 0;
            padding-left: 1.5rem;
        }
        
        .info-box {
            background: rgba(124, 58, 237, 0.1);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            color: #a1a1aa;
            font-size: 0.9rem;
        }
        
        .info-box i {
            color: #7c3aed;
            margin-right: 0.5rem;
        }
        
        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #e4e4e7;
            margin: 1.5rem 0 1rem 0;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(124, 58, 237, 0.2);
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <h1><i class="fas fa-building"></i> Register Your Company</h1>
                <p>Join our bug bounty platform and secure your assets</p>
            </div>
            
            <% if (errors.length > 0) { %>
                <div class="alert-error">
                    <ul>
                        <% errors.forEach(error => { %>
                            <li><%= error %></li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>
            
            <div class="info-box">
                <i class="fas fa-info-circle"></i>
                Your registration will be reviewed by our admin team. You'll receive notification once approved.
            </div>
            
            <form action="/company/register" method="POST">
                
                <div class="section-title">Company Information</div>
                
                <div class="form-group">
                    <label class="form-label">
                        Company Name <span class="required">*</span>
                    </label>
                    <input type="text" name="company_name" class="form-input" 
                           value="<%= formData.company_name || '' %>" required
                           placeholder="Acme Corporation">
                </div>
                
                <div class="form-group">
                    <label class="form-label">
                        Company Email <span class="required">*</span>
                    </label>
                    <input type="email" name="company_email" class="form-input" 
                           value="<%= formData.company_email || '' %>" required
                           placeholder="security@company.com">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Website</label>
                    <input type="url" name="website" class="form-input" 
                           value="<%= formData.website || '' %>"
                           placeholder="https://company.com">
                </div>
                
                <div class="form-group">
                    <label class="form-label">Company Description</label>
                    <textarea name="description" class="form-textarea" 
                              placeholder="Tell us about your company..."><%= formData.description || '' %></textarea>
                </div>
                
                <div class="section-title">Contact Person</div>
                
                <div class="form-group">
                    <label class="form-label">
                        Full Name <span class="required">*</span>
                    </label>
                    <input type="text" name="contact_name" class="form-input" 
                           value="<%= formData.contact_name || '' %>" required
                           placeholder="John Doe">
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            Email <span class="required">*</span>
                        </label>
                        <input type="email" name="contact_email" class="form-input" 
                               value="<%= formData.contact_email || '' %>" required
                               placeholder="john@company.com">
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input type="tel" name="contact_phone" class="form-input" 
                               value="<%= formData.contact_phone || '' %>"
                               placeholder="+1 234 567 890">
                    </div>
                </div>
                
                <button type="submit" class="btn-submit">
                    <i class="fas fa-paper-plane"></i> Submit Registration
                </button>
                
            </form>
            
            <p style="text-align: center; margin-top: 1.5rem; color: #71717a; font-size: 0.9rem;">
                Already have an account? <a href="/auth/login" style="color: #7c3aed;">Login</a>
            </p>
        </div>
    </div>
</body>
</html>