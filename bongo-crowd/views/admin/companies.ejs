<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | BONGO-CROWD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        .admin-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .btn-create {
            padding: 0.75rem 1.5rem;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }
        
        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
        }
        
        .companies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
        }
        
        .company-card {
            background: rgba(21, 21, 32, 0.8);
            border: 1px solid rgba(124, 58, 237, 0.15);
            border-radius: 12px;
            padding: 1.5rem;
            transition: all 0.3s ease;
        }
        
        .company-card:hover {
            border-color: rgba(124, 58, 237, 0.4);
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.1);
        }
        
        .company-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        
        .company-logo {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            overflow: hidden;
        }
        
        .company-logo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .company-info h3 {
            font-size: 1.2rem;
            font-weight: 600;
            margin: 0 0 0.25rem 0;
        }
        
        .company-info p {
            color: #71717a;
            font-size: 0.85rem;
            margin: 0;
        }
        
        .company-stats {
            display: flex;
            gap: 1.5rem;
            padding: 1rem 0;
            border-top: 1px solid rgba(124, 58, 237, 0.1);
            border-bottom: 1px solid rgba(124, 58, 237, 0.1);
            margin-bottom: 1rem;
        }
        
        .stat {
            text-align: center;
        }
        
        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #7c3aed;
        }
        
        .stat-label {
            font-size: 0.75rem;
            color: #71717a;
            text-transform: uppercase;
        }
        
        .company-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .company-actions a {
            flex: 1;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .btn-edit {
            background: rgba(124, 58, 237, 0.1);
            border: 1px solid rgba(124, 58, 237, 0.3);
            color: #7c3aed;
        }
        
        .btn-edit:hover {
            background: rgba(124, 58, 237, 0.2);
        }
        
        .btn-view {
            background: rgba(6, 182, 212, 0.1);
            border: 1px solid rgba(6, 182, 212, 0.3);
            color: #06b6d4;
        }
        
        .btn-view:hover {
            background: rgba(6, 182, 212, 0.2);
        }
        
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(21, 21, 32, 0.8);
            border: 1px solid rgba(124, 58, 237, 0.15);
            border-radius: 12px;
        }
        
        .empty-state i {
            font-size: 4rem;
            color: #71717a;
            margin-bottom: 1rem;
        }
        
        .empty-state h3 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        
        .empty-state p {
            color: #71717a;
            margin-bottom: 1.5rem;
        }
        
        .alert {
            padding: 1rem 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }
        
        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #10b981;
        }
        
        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #ef4444;
        }
    </style>
</head>
<body>
    <nav style="background: rgba(21, 21, 32, 0.95); border-bottom: 1px solid rgba(124, 58, 237, 0.2); padding: 1rem 2rem;">
        <div style="max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
            <a href="/" style="font-size: 1.5rem; font-weight: 800; text-decoration: none;">
                <span style="color: #7c3aed;">◈</span>
                <span style="background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">BONGO-CROWD</span>
            </a>
            <div style="display: flex; gap: 2rem;">
                <a href="/admin/dashboard" style="color: #a1a1aa; text-decoration: none;">Dashboard</a>
                <a href="/admin/companies" style="color: #7c3aed; text-decoration: none; font-weight: 600;">Companies</a>
                <a href="/admin/programs" style="color: #a1a1aa; text-decoration: none;">Programs</a>
                <a href="/admin/users" style="color: #a1a1aa; text-decoration: none;">Users</a>
                <a href="/auth/logout" style="color: #ef4444; text-decoration: none;">Logout</a>
            </div>
        </div>
    </nav>
    
    
    <div class="admin-container">
        <% if (success.length > 0) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        
        <% if (error.length > 0) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        
        <div class="admin-header">
            <h1 class="admin-title">Manage Companies</h1>
            <a href="/admin/companies/new" class="btn-create">
                <i class="fas fa-plus"></i> Create Company
            </a>
        </div>
        
        <% if (companies.length > 0) { %>
            <div class="companies-grid">
                <% companies.forEach(company => { %>
                    <div class="company-card">
                        <div class="company-header">
                            <div class="company-logo">
                                <% if (company.logo_url) { %>
                                    <img src="<%= company.logo_url %>" alt="<%= company.name %>">
                                <% } else { %>
                                    <i class="fas fa-building"></i>
                                <% } %>
                            </div>
                            <div class="company-info">
                                <h3><%= company.name %></h3>
                                <p><%= company.email %></p>
                            </div>
                        </div>
                        
                        <div class="company-stats">
                            <div class="stat">
                                <div class="stat-value"><%= company.program_count || 0 %></div>
                                <div class="stat-label">Programs</div>
                            </div>
                        </div>
                        
                        <div class="company-actions">
                            <a href="/admin/companies/<%= company.id %>/edit" class="btn-edit">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <a href="/programs?company=<%= company.id %>" class="btn-view">
                                <i class="fas fa-eye"></i> View
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-building"></i>
                <h3>No Companies Yet</h3>
                <p>Create your first company to start running bug bounty programs.</p>
                <a href="/admin/companies/new" class="btn-create">
                    <i class="fas fa-plus"></i> Create Company
                </a>
            </div>
        <% } %>
    </div>
</body>
</html>