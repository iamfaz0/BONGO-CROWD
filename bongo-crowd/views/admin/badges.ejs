<% title = 'Manage Badges' %>

<div class="admin-page">
    <div class="admin-header">
        <h1><i class="fas fa-medal"></i> Manage Badges</h1>
        <a href="/admin/badges/create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create Badge
        </a>
    </div>

    <% if (success && success.length > 0) { %>
    <div class="alert alert-success">
        <i class="fas fa-check-circle"></i> <%= success %>
    </div>
    <% } %>

    <% if (error && error.length > 0) { %>
    <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i> <%= error %>
    </div>
    <% } %>

    <div class="badges-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Badge</th>
                    <th>Category</th>
                    <th>Rarity</th>
                    <th>Points</th>
                    <th>Earned By</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% badges.forEach(badge => { %>
                <tr class="<%= badge.is_active ? '' : 'inactive' %>">
                    <td>
                        <div class="badge-info">
                            <div class="badge-icon-small" style="background: linear-gradient(135deg, <%= badge.gradient_start %> 0%, <%= badge.gradient_end %> 100%)">
                                <%= badge.icon %>
                            </div>
                            <div class="badge-text">
                                <span class="badge-name"><%= badge.name %></span>
                                <span class="badge-description"><%= badge.description %></span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge-category <%= badge.category %>">
                            <%= badge.category.charAt(0).toUpperCase() + badge.category.slice(1) %>
                        </span>
                    </td>
                    <td>
                        <span class="badge-rarity <%= badge.rarity %>">
                            <%= badge.rarity.charAt(0).toUpperCase() + badge.rarity.slice(1) %>
                        </span>
                    </td>
                    <td>
                        <span class="badge-points">+<%= badge.points_reward %></span>
                    </td>
                    <td>
                        <span class="earned-count"><%= badge.earned_count %> users</span>
                    </td>
                    <td>
                        <% if (badge.is_active) { %>
                        <span class="status-badge active">Active</span>
                        <% } else { %>
                        <span class="status-badge inactive">Inactive</span>
                        <% } %>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <a href="/admin/badges/<%= badge.id %>/edit" class="btn btn-sm btn-secondary" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <% if (badge.earned_count == 0) { %>
                            <form action="/admin/badges/<%= badge.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Are you sure you want to delete this badge?')">
                                <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                            <% } else { %>
                            <form action="/admin/badges/<%= badge.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('This badge has been earned by <%= badge.earned_count %> users. It will be deactivated instead. Continue?')">
                                <button type="submit" class="btn btn-sm btn-warning" title="Deactivate">
                                    <i class="fas fa-ban"></i>
                                </button>
                            </form>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <% if (badges.length === 0) { %>
    <div class="empty-state">
        <i class="fas fa-medal"></i>
        <h3>No Badges Yet</h3>
        <p>Create your first badge to start rewarding hackers</p>
        <a href="/admin/badges/create" class="btn btn-primary">Create Badge</a>
    </div>
    <% } %>
</div>

<style>
.admin-page {
    padding: var(--space-xl);
    max-width: 1400px;
    margin: 0 auto;
}

.admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-color);
}

.admin-header h1 {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1.75rem;
    font-weight: 700;
}

.badges-table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    overflow: hidden;
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
}

.admin-table th {
    background: var(--bg-tertiary);
    padding: var(--space-md) var(--space-lg);
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    font-weight: 600;
    border-bottom: 1px solid var(--border-color);
}

.admin-table td {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
}

.admin-table tr:last-child td {
    border-bottom: none;
}

.admin-table tr.inactive {
    opacity: 0.6;
    background: var(--bg-tertiary);
}

.admin-table tr:hover:not(.inactive) {
    background: var(--glass);
}

.badge-info {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.badge-icon-small {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
}

.badge-text {
    display: flex;
    flex-direction: column;
}

.badge-name {
    font-weight: 600;
    color: var(--text-primary);
}

.badge-description {
    font-size: 0.75rem;
    color: var(--text-muted);
    max-width: 250px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.badge-category {
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
}

.badge-category.skill {
    background: rgba(124, 58, 237, 0.15);
    color: #a78bfa;
}

.badge-category.achievement {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
}

.badge-category.activity {
    background: rgba(16, 185, 129, 0.15);
    color: #34d399;
}

.badge-category.special {
    background: rgba(236, 72, 153, 0.15);
    color: #f472b6;
}

.badge-rarity {
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
}

.badge-rarity.common {
    background: rgba(148, 163, 184, 0.15);
    color: #94a3b8;
}

.badge-rarity.rare {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
}

.badge-rarity.epic {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
}

.badge-rarity.legendary {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
}

.badge-points {
    font-weight: 700;
    color: var(--success);
}

.earned-count {
    font-size: 0.875rem;
    color: var(--text-secondary);
}

.status-badge {
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
}

.status-badge.active {
    background: rgba(34, 197, 94, 0.15);
    color: var(--success);
}

.status-badge.inactive {
    background: rgba(239, 68, 68, 0.15);
    color: var(--error);
}

.action-buttons {
    display: flex;
    gap: var(--space-xs);
}

.inline-form {
    display: inline;
}

.empty-state {
    text-align: center;
    padding: var(--space-3xl);
    background: var(--bg-card);
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-xl);
}

.empty-state i {
    font-size: 3rem;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
}

.empty-state h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
}

.empty-state p {
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
}

.alert {
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
}

.alert-success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: var(--success);
}

.alert-error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: var(--error);
}

@media (max-width: 1024px) {
    .admin-table {
        display: block;
        overflow-x: auto;
    }
}
</style>
