<% title = 'Leaderboard' %>
<% style = '<style>' + `
.leaderboard-page {
    padding: var(--space-3xl) 0;
}

.page-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
}

.page-header h1 {
    font-size: 3rem;
    font-weight: 800;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-md);
}

.page-header p {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
}

/* Top 3 Podium */
.podium {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: var(--space-xl);
    margin-bottom: var(--space-3xl);
    padding: var(--space-2xl) 0;
}

.podium-item {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    text-align: center;
    position: relative;
    transition: var(--transition);
    min-width: 220px;
}

.podium-item:hover {
    transform: translateY(-8px);
    border-color: var(--border-hover);
}

.podium-item.first {
    order: 2;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    background: linear-gradient(180deg, rgba(251, 191, 36, 0.1) 0%, var(--bg-card) 100%);
    border-color: rgba(251, 191, 36, 0.4);
    box-shadow: 0 20px 60px rgba(251, 191, 36, 0.15);
    z-index: 3;
}

.podium-item.second {
    order: 1;
    transform: translateY(20px);
    background: linear-gradient(180deg, rgba(148, 163, 184, 0.1) 0%, var(--bg-card) 100%);
    border-color: rgba(148, 163, 184, 0.4);
    box-shadow: 0 15px 40px rgba(148, 163, 184, 0.1);
    z-index: 2;
}

.podium-item.third {
    order: 3;
    transform: translateY(40px);
    background: linear-gradient(180deg, rgba(180, 83, 9, 0.1) 0%, var(--bg-card) 100%);
    border-color: rgba(180, 83, 9, 0.4);
    box-shadow: 0 15px 40px rgba(180, 83, 9, 0.1);
    z-index: 1;
}

.podium-avatar {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full);
    margin: 0 auto var(--space-md);
    border: 3px solid var(--border-color);
    overflow: hidden;
    position: relative;
}

.podium-item.first .podium-avatar {
    border-color: #fbbf24;
    box-shadow: 0 0 40px rgba(251, 191, 36, 0.3);
}

.podium-item.second .podium-avatar {
    border-color: #94a3b8;
    box-shadow: 0 0 30px rgba(148, 163, 184, 0.2);
}

.podium-item.third .podium-avatar {
    border-color: #b45309;
    box-shadow: 0 0 30px rgba(180, 83, 9, 0.2);
}

.podium-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.podium-rank {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.25rem;
}

.podium-item.first .podium-rank {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #78350f;
    box-shadow: 0 4px 20px rgba(251, 191, 36, 0.4);
}

.podium-item.second .podium-rank {
    background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
    color: white;
    box-shadow: 0 4px 20px rgba(148, 163, 184, 0.3);
}

.podium-item.third .podium-rank {
    background: linear-gradient(135deg, #b45309 0%, #92400e 100%);
    color: white;
    box-shadow: 0 4px 20px rgba(180, 83, 9, 0.3);
}

.podium-name {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
}

.podium-rank-label {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
}

.rank-legend {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.15) 0%, rgba(251, 191, 36, 0.05) 100%);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
}

.rank-elite {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(139, 92, 246, 0.05) 100%);
    color: #a78bfa;
    border: 1px solid rgba(139, 92, 246, 0.3);
}

.rank-expert {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
}

.podium-points {
    font-size: 1.5rem;
    font-weight: 800;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-xs);
}

.podium-reports {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

/* Table Controls */
.table-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
    gap: var(--space-md);
}

.period-selector {
    display: flex;
    gap: var(--space-xs);
    background: var(--bg-tertiary);
    padding: 6px;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
}

.period-btn {
    padding: 10px 20px;
    border: none;
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: var(--transition-fast);
}

.period-btn:hover {
    color: var(--text-primary);
}

.period-btn.active {
    background: var(--gradient-primary);
    color: white;
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
}

.search-box {
    position: relative;
    flex: 1;
    max-width: 300px;
}

.search-box input {
    width: 100%;
    padding: 12px 16px 12px 44px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    background: var(--bg-tertiary);
    color: var(--text-primary);
    font-size: 0.9375rem;
    transition: var(--transition);
}

.search-box input::placeholder {
    color: var(--text-muted);
}

.search-box input:focus {
    outline: none;
    border-color: var(--hp-purple);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
}

.search-box i {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.875rem;
}

/* Leaderboard Table */
.leaderboard-table-container {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    overflow: hidden;
}

.leaderboard-table {
    width: 100%;
    border-collapse: collapse;
}

.leaderboard-table th {
    text-align: left;
    padding: var(--space-md) var(--space-xl);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    font-weight: 600;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-tertiary);
}

.leaderboard-table td {
    padding: var(--space-md) var(--space-xl);
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
}

.leaderboard-table tr:last-child td {
    border-bottom: none;
}

.leaderboard-table tbody tr {
    transition: var(--transition-fast);
}

.leaderboard-table tbody tr:hover {
    background: var(--glass);
}

/* Rank Styles */
.rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 0.875rem;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
}

.rank-1 {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #78350f;
}

.rank-2 {
    background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
    color: white;
}

.rank-3 {
    background: linear-gradient(135deg, #b45309 0%, #92400e 100%);
    color: white;
}

/* User Cell */
.user-cell {
    display: flex;
    align-items: center;
    gap: var(--space-md);
}

.user-avatar {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    border: 2px solid var(--border-color);
    overflow: hidden;
    flex-shrink: 0;
}

.user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.user-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.user-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9375rem;
}

.user-tag {
    display: inline-flex;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.user-tag.legend {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
}

.user-tag.elite {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
    border: 1px solid rgba(139, 92, 246, 0.3);
}

.user-tag.expert {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
}

.user-tag.hunter {
    background: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
}

.user-tag.novice {
    background: rgba(148, 163, 184, 0.15);
    color: #94a3b8;
    border: 1px solid rgba(148, 163, 184, 0.3);
}

/* Stats Cells */
.stat-value {
    font-weight: 700;
    font-size: 1rem;
}

.stat-value.points {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.stat-value.reputation {
    color: var(--hp-purple-light);
}

.stat-value.reports {
    color: var(--hp-cyan);
}

/* Pagination */
.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xl);
    border-top: 1px solid var(--border-color);
}

.page-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 var(--space-sm);
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
    border-radius: var(--radius);
    color: var(--text-secondary);
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition-fast);
}

.page-btn:hover:not(:disabled) {
    border-color: var(--hp-purple);
    color: var(--text-primary);
}

.page-btn.active {
    background: var(--gradient-primary);
    border-color: transparent;
    color: white;
}

.page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.page-dots {
    color: var(--text-muted);
    padding: 0 var(--space-xs);
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: var(--space-3xl);
}

.empty-state-icon {
    font-size: 4rem;
    margin-bottom: var(--space-lg);
    opacity: 0.5;
}

.empty-state h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
}

.empty-state p {
    color: var(--text-secondary);
}

/* Responsive */
@media (max-width: 768px) {
    .page-header h1 {
        font-size: 2rem;
    }
    
    .podium {
        flex-direction: column;
        align-items: center;
    }
    
    .podium-item {
        min-width: 280px;
    }
    
    .podium-item.first,
    .podium-item.second,
    .podium-item.third {
        transform: none;
        order: initial;
    }
    
    .podium-item.second,
    .podium-item.third {
        margin-top: var(--space-md);
    }
    
    .table-controls {
        flex-direction: column;
        align-items: stretch;
    }
    
    .search-box {
        max-width: none;
    }
    
    .leaderboard-table th:nth-child(4),
    .leaderboard-table td:nth-child(4) {
        display: none;
    }
    
    .user-avatar {
        width: 36px;
        height: 36px;
    }
}
` + '</style>' %>

<div class="leaderboard-page">
    <div class="container">
        <div class="page-header">
            <h1>Hacker Leaderboard</h1>
            <p>Top security researchers making the digital world safer. Rankings based on valid vulnerability reports and reputation points.</p>
        </div>

        <!-- Top 3 Podium -->
        <% if (topHackers && topHackers.length >= 3) { %>
        <div class="podium">
            <!-- 2nd Place -->
            <div class="podium-item second">
                <div class="podium-rank">2</div>
                <div class="podium-avatar">
                    <img src="<%= topHackers[1].avatar_url || '/images/default-avatar.png' %>" alt="<%= topHackers[1].username %>">
                </div>
                <div class="podium-name">@<%= topHackers[1].username %></div>
                <% if (topHackers[1].rank) { %>
                <div class="podium-rank-label rank-<%= topHackers[1].rank %>"><%= topHackers[1].rank.charAt(0).toUpperCase() + topHackers[1].rank.slice(1) %></div>
                <% } %>
                <div class="podium-points"><%= (topHackers[1].reputation || 0).toLocaleString() %> rep</div>
                <div class="podium-reports"><%= topHackers[1].valid_reports || 0 %> valid reports</div>
            </div>
            
            <!-- 1st Place -->
            <div class="podium-item first">
                <div class="podium-rank">1</div>
                <div class="podium-avatar">
                    <img src="<%= topHackers[0].avatar_url || '/images/default-avatar.png' %>" alt="<%= topHackers[0].username %>">
                </div>
                <div class="podium-name">@<%= topHackers[0].username %></div>
                <% if (topHackers[0].rank) { %>
                <div class="podium-rank-label rank-<%= topHackers[0].rank %>"><%= topHackers[0].rank.charAt(0).toUpperCase() + topHackers[0].rank.slice(1) %></div>
                <% } %>
                <div class="podium-points"><%= (topHackers[0].reputation || 0).toLocaleString() %> rep</div>
                <div class="podium-reports"><%= topHackers[0].valid_reports || 0 %> valid reports</div>
            </div>
            
            <!-- 3rd Place -->
            <div class="podium-item third">
                <div class="podium-rank">3</div>
                <div class="podium-avatar">
                    <img src="<%= topHackers[2].avatar_url || '/images/default-avatar.png' %>" alt="<%= topHackers[2].username %>">
                </div>
                <div class="podium-name">@<%= topHackers[2].username %></div>
                <% if (topHackers[2].rank) { %>
                <div class="podium-rank-label rank-<%= topHackers[2].rank %>"><%= topHackers[2].rank.charAt(0).toUpperCase() + topHackers[2].rank.slice(1) %></div>
                <% } %>
                <div class="podium-points"><%= (topHackers[2].reputation || 0).toLocaleString() %> rep</div>
                <div class="podium-reports"><%= topHackers[2].valid_reports || 0 %> valid reports</div>
            </div>
        </div>
        <% } %>

        <!-- Table Controls -->
        <div class="table-controls">
            <div class="period-selector">
                <button class="period-btn <%= period === 'all' ? 'active' : '' %>" data-period="all">All Time</button>
                <button class="period-btn <%= period === 'year' ? 'active' : '' %>" data-period="year">This Year</button>
                <button class="period-btn <%= period === 'month' ? 'active' : '' %>" data-period="month">This Month</button>
            </div>
            
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search by username..." value="<%= search || '' %>" id="searchInput">
            </div>
        </div>

        <!-- Leaderboard Table -->
        <div class="leaderboard-table-container">
            <% if (hackers && hackers.length > 0) { %>
            <table class="leaderboard-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Hacker</th>
                        <th>Rank</th>
                        <th>Valid Reports</th>
                        <th>Reputation</th>
                    </tr>
                </thead>
                <tbody>
                    <% hackers.forEach((hacker, index) => { 
                        const displayRank = (page - 1) * perPage + index + 1;
                    %>
                    <tr>
                        <td>
                            <span class="rank <%= displayRank <= 3 ? 'rank-' + displayRank : '' %>">
                                <%= displayRank %>
                            </span>
                        </td>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar">
                                    <img src="<%= hacker.avatar_url || '/images/default-avatar.png' %>" alt="<%= hacker.username %>">
                                </div>
                                <div class="user-info">
                                    <span class="user-name">@<%= hacker.username %></span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <% if (hacker.rank) { %>
                            <span class="user-tag <%= hacker.rank %>"><%= hacker.rank.charAt(0).toUpperCase() + hacker.rank.slice(1) %></span>
                            <% } else { %>
                            <span class="user-tag novice">Novice</span>
                            <% } %>
                        </td>
                        <td>
                            <span class="stat-value reports"><%= hacker.valid_reports || 0 %></span>
                        </td>
                        <td>
                            <span class="stat-value reputation"><%= (hacker.reputation || 0).toLocaleString() %></span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">🏆</div>
                <h3>No hackers found</h3>
                <p>Try adjusting your search or filters</p>
            </div>
            <% } %>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pagination">
                <button class="page-btn" <%= page <= 1 ? 'disabled' : '' %> data-page="<%= page - 1 %>">
                    <i class="fas fa-chevron-left"></i>
                </button>
                
                <% 
                let startPage = Math.max(1, page - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }
                
                if (startPage > 1) { %>
                    <button class="page-btn" data-page="1">1</button>
                    <% if (startPage > 2) { %>
                        <span class="page-dots">...</span>
                    <% } %>
                <% } %>
                
                <% for (let i = startPage; i <= endPage; i++) { %>
                    <button class="page-btn <%= i === page ? 'active' : '' %>" data-page="<%= i %>">
                        <%= i %>
                    </button>
                <% } %>
                
                <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                        <span class="page-dots">...</span>
                    <% } %>
                    <button class="page-btn" data-page="<%= totalPages %>"><%= totalPages %></button>
                <% } %>
                
                <button class="page-btn" <%= page >= totalPages ? 'disabled' : '' %> data-page="<%= page + 1 %>">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
// Handle period filter clicks
document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        const period = this.dataset.period;
        const url = new URL(window.location);
        url.searchParams.set('period', period);
        url.searchParams.delete('page'); // Reset to page 1
        window.location = url;
    });
});

// Handle search input
const searchInput = document.getElementById('searchInput');
let searchTimeout;
searchInput?.addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        const url = new URL(window.location);
        if (this.value) {
            url.searchParams.set('search', this.value);
        } else {
            url.searchParams.delete('search');
        }
        url.searchParams.delete('page');
        window.location = url;
    }, 500);
});

// Handle pagination
document.querySelectorAll('.page-btn:not(:disabled)').forEach(btn => {
    btn.addEventListener('click', function() {
        const page = this.dataset.page;
        const url = new URL(window.location);
        url.searchParams.set('page', page);
        window.location = url;
    });
});
</script>