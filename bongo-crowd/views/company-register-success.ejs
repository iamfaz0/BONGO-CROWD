<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | BONGO-CROWD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .success-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
        }
        
        .success-card {
            width: 100%;
            max-width: 500px;
            background: rgba(21, 21, 32, 0.95);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 16px;
            padding: 3rem;
            text-align: center;
        }
        
        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.5rem;
            color: white;
        }
        
        .success-card h1 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #10b981;
            margin-bottom: 1rem;
        }
        
        .success-card p {
            color: #a1a1aa;
            margin-bottom: 0.5rem;
            line-height: 1.6;
        }
        
        .company-name {
            color: #e4e4e7;
            font-weight: 600;
            font-size: 1.2rem;
            margin: 1rem 0;
            padding: 1rem;
            background: rgba(124, 58, 237, 0.1);
            border-radius: 8px;
        }
        
        .info-box {
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid rgba(245, 158, 11, 0.2);
            border-radius: 8px;
            padding: 1rem;
            margin: 1.5rem 0;
            color: #f59e0b;
            font-size: 0.9rem;
        }
        
        .btn-home {
            display: inline-block;
            padding: 1rem 2rem;
            background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            text-decoration: none;
            margin-top: 1.5rem;
            transition: all 0.3s ease;
        }
        
        .btn-home:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
        }
    </style>
</head>
<body>
    <div class="success-container">
        <div class="success-card">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
            
            <h1>Registration Submitted!</h1>
            
            <p>Thank you for registering your company with BONGO-CROWD.</p>
            
            <div class="company-name">
                <i class="fas fa-building"></i> <%= companyName %>
            </div>
            
            <div class="info-box">
                <i class="fas fa-clock"></i>
                <strong>Under Review</strong><br>
                Our admin team will review your application and send you login credentials once approved.
            </div>
            
            <p>You'll receive an email notification once your company is approved.</p>
            
            <a href="/" class="btn-home">
                <i class="fas fa-home"></i> Back to Homepage
            </a>
        </div>
    </div>
</body>
</html>