<div class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <a href="/" class="auth-logo">
                <span class="logo-icon">◈</span>
                <span class="logo-text">BONGO-CROWD</span>
            </a>
            <h1>Create an account</h1>
            <p>Join the community of security researchers</p>
        </div>

        <% if (errors.length) { %>
            <div class="alert alert-error" style="margin-bottom: var(--space-lg);">
                <ul style="margin: 0; padding-left: var(--space-lg);">
                    <% errors.forEach(err => { %>
                        <li><%= err.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form action="/auth/register" method="POST" class="auth-form">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md);">
                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input type="text" id="username" name="username" required 
                           value="<%= formData.username || '' %>" placeholder="hunter_255" class="form-input">
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="display_name">Display Name</label>
                    <input type="text" id="display_name" name="display_name" required
                           value="<%= formData.display_name || '' %>" placeholder="John Doe" class="form-input">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input type="email" id="email" name="email" required
                       value="<%= formData.email || '' %>" placeholder="you@example.com" class="form-input">
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input type="password" id="password" name="password" required 
                       placeholder="Min 8 characters" class="form-input">
                <span class="form-hint">Must be at least 8 characters long</span>
            </div>

            <div class="form-group" style="margin-top: var(--space-md);">
                <label class="checkbox" style="display: flex; align-items: flex-start; gap: 12px; cursor: pointer; color: var(--text-secondary); font-size: 0.875rem;">
                    <input type="checkbox" name="terms" required style="margin-top: 3px; accent-color: var(--hp-purple);">
                    <span>I agree to the <a href="#" style="color: var(--hp-cyan-light);">Terms of Service</a> and <a href="#" style="color: var(--hp-cyan-light);">Privacy Policy</a></span>
                </label>
            </div>

            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; margin-top: var(--space-md);">Create Account</button>
        </form>

        <div class="auth-divider">
            <span>Or sign up with</span>
        </div>

        <a href="/auth/google" class="btn btn-ghost btn-lg" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 12px;">
            <i class="fab fa-google"></i>
            Google
        </a>

        <div class="auth-footer">
            <p style="color: var(--text-muted);">Already have an account? <a href="/auth/login" style="color: var(--hp-cyan-light); font-weight: 600;">Sign in</a></p>
        </div>
    </div>

    <div class="auth-image">
        <div class="auth-image-content">
            <h2>Start Your Bug Hunting Journey</h2>
            <p>Join thousands of researchers finding vulnerabilities and earning rewards.</p>
            
            <ul class="auth-features">
                <li><i class="fas fa-check"></i> Access exclusive bug bounty programs</li>
                <li><i class="fas fa-check"></i> Earn competitive rewards</li>
                <li><i class="fas fa-check"></i> Build your security reputation</li>
                <li><i class="fas fa-check"></i> Connect with the community</li>
            </ul>
        </div>
    </div>
</div>

<style>
.auth-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    background: var(--bg-primary);
}

.auth-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-2xl);
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
}

.auth-header {
    text-align: center;
    margin-bottom: var(--space-xl);
}

.auth-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-xl);
}

.auth-logo .logo-icon,
.auth-logo .logo-text {
    background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 50%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.auth-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
}

.auth-header p {
    color: var(--text-muted);
    font-size: 1rem;
}

.auth-form {
    margin-bottom: var(--space-md);
}

.auth-divider {
    text-align: center;
    margin: var(--space-xl) 0;
    position: relative;
}

.auth-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.3), transparent);
}

.auth-divider span {
    background: var(--bg-primary);
    padding: 0 var(--space-md);
    position: relative;
    color: var(--text-muted);
    font-size: 0.875rem;
}

.auth-footer {
    text-align: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(124, 58, 237, 0.15);
}

.auth-image {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(6, 182, 212, 0.2) 100%),
                url('/images/auth-bg.jpg') center/cover;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
    position: relative;
    overflow: hidden;
}

.auth-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.2) 0%, transparent 70%);
}

.auth-image-content {
    max-width: 400px;
    position: relative;
    z-index: 1;
}

.auth-image-content h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: var(--space-md);
    background: linear-gradient(135deg, #fff 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.auth-image-content p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.125rem;
    margin-bottom: var(--space-xl);
}

.auth-features {
    list-style: none;
    text-align: left;
}

.auth-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-md);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
}

.auth-features i {
    width: 24px;
    height: 24px;
    background: rgba(124, 58, 237, 0.3);
    border: 1px solid rgba(124, 58, 237, 0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    color: var(--hp-cyan-light);
}

@media (max-width: 768px) {
    .auth-page {
        grid-template-columns: 1fr;
    }
    
    .auth-image {
        display: none;
    }
    
    .auth-container {
        padding: var(--space-xl);
    }
    
    .form-row {
        grid-template-columns: 1fr !important;
    }
}
</style>
