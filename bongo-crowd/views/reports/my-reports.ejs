<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | BongoCrowd</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
      min-height: 100vh;
      color: #e2e8f0;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .page-header h1 {
      font-size: 2.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #7c0aed 0%, #06b6d4 50%, #7c0aed 100%);
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 5s ease infinite;
      margin-bottom: 0.5rem;
    }

    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .page-header p {
      color: #94a3b8;
      font-size: 1rem;
    }

    .reports-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .report-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transition: all 0.3s ease;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 1rem;
    }

    .report-card:hover {
      background: rgba(124, 10, 237, 0.08);
      border-color: rgba(124, 10, 237, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(124, 10, 237, 0.15);
    }

    .report-main {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .report-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .report-id {
      font-family: 'SF Mono', Monaco, monospace;
      font-size: 0.875rem;
      color: #7c0aed;
      text-decoration: none;
      font-weight: 600;
      padding: 0.25rem 0.5rem;
      background: rgba(124, 10, 237, 0.1);
      border-radius: 6px;
      transition: all 0.2s ease;
    }

    .report-id:hover {
      background: rgba(124, 10, 237, 0.2);
      color: #a855f7;
    }

    .report-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: #f8fafc;
      line-height: 1.4;
    }

    .report-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      font-size: 0.875rem;
      color: #94a3b8;
    }

    .program-name {
      color: #06b6d4;
      font-weight: 500;
    }

    .program-name::before {
      content: '🎯 ';
    }

    .date-submitted::before {
      content: '📅 ';
    }

    .bounty-amount {
      color: #22c55e;
      font-weight: 600;
    }

    .bounty-amount::before {
      content: '💰 ';
    }

    .report-badges {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
    }

    .badge {
      padding: 0.375rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.025em;
      white-space: nowrap;
    }

    /* Severity badges */
    .severity-critical {
      background: rgba(239, 68, 68, 0.15);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .severity-high {
      background: rgba(249, 115, 22, 0.15);
      color: #f97316;
      border: 1px solid rgba(249, 115, 22, 0.3);
    }

    .severity-medium {
      background: rgba(234, 179, 8, 0.15);
      color: #eab308;
      border: 1px solid rgba(234, 179, 8, 0.3);
    }

    .severity-low {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .severity-info {
      background: rgba(6, 182, 212, 0.15);
      color: #06b6d4;
      border: 1px solid rgba(6, 182, 212, 0.3);
    }

    /* Status badges */
    .status-submitted {
      background: rgba(148, 163, 184, 0.15);
      color: #94a3b8;
      border: 1px solid rgba(148, 163, 184, 0.3);
    }

    .status-under_review {
      background: rgba(124, 10, 237, 0.15);
      color: #a855f7;
      border: 1px solid rgba(124, 10, 237, 0.3);
    }

    .status-needs_info {
      background: rgba(234, 179, 8, 0.15);
      color: #eab308;
      border: 1px solid rgba(234, 179, 8, 0.3);
    }

    .status-resolved {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .status-accepted {
      background: rgba(6, 182, 212, 0.15);
      color: #06b6d4;
      border: 1px solid rgba(6, 182, 212, 0.3);
    }

    .status-rejected {
      background: rgba(239, 68, 68, 0.15);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .status-closed {
      background: rgba(100, 116, 139, 0.15);
      color: #64748b;
      border: 1px solid rgba(100, 116, 139, 0.3);
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      background: rgba(255, 255, 255, 0.02);
      border: 1px dashed rgba(255, 255, 255, 0.1);
      border-radius: 16px;
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
      opacity: 0.5;
    }

    .empty-state h3 {
      color: #f8fafc;
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .empty-state p {
      color: #94a3b8;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 1.75rem;
      }

      .report-card {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .report-badges {
        flex-direction: row;
        justify-content: flex-start;
        align-items: center;
      }

      .report-meta {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.375rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="page-header">
      <h1><%= title %></h1>
      <p>Track and manage your submitted vulnerability reports</p>
    </div>

    <% if (reports && reports.length > 0) { %>
      <div class="reports-grid">
        <% reports.forEach(report => { %>
          <div class="report-card">
            <div class="report-main">
              <div class="report-header">
                <a href="/reports/<%= report.report_id %>" class="report-id">#<%= report.report_id %></a>
                <span class="report-title"><%= report.title %></span>
              </div>
              <div class="report-meta">
                <span class="program-name"><%= report.program_name %></span>
                <span class="date-submitted"><%= new Date(report.created_at).toLocaleDateString('en-US', { 
                  year: 'numeric', 
                  month: 'short', 
                  day: 'numeric' 
                }) %></span>
                <% if (report.bounty_amount) { %>
                  <span class="bounty-amount">$<%= parseFloat(report.bounty_amount).toLocaleString() %></span>
                <% } %>
              </div>
            </div>
            <div class="report-badges">
              <span class="badge severity-<%= report.severity.toLowerCase() %>">
                <%= report.severity %>
              </span>
              <span class="badge status-<%= report.status.toLowerCase() %>">
                <%= report.status.replace('_', ' ') %>
              </span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <h3>No Reports Yet</h3>
        <p>You haven't submitted any vulnerability reports. Start hunting to earn rewards!</p>
      </div>
    <% } %>
  </div>
</body>
</html>
