                </div>
            </form>
        </div>
    </div>

    <script>
        // Update reward info when program is selected
        document.getElementById('program_id').addEventListener('change', function() {
            const selected = this.options[this.selectedIndex];
            const reward = selected.getAttribute('data-reward');
            
            // Remove existing reward display
            const existingReward = document.querySelector('.program-reward');
            if (existingReward) {
                existingReward.remove();
            }
            
            if (reward && reward !== 'null-null') {
                const rewardDiv = document.createElement('div');
                rewardDiv.className = 'program-reward';
                rewardDiv.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Bounty Range: $${reward}
                `;
                this.parentNode.appendChild(rewardDiv);
            }
        });

        // Configure marked.js options
        marked.setOptions({
            breaks: true,
            gfm: true,
            headerIds: false,
            sanitize: false
        });

        // Bounty Estimate Widget
        const programSelect = document.getElementById('program_id');
        const severitySelect = document.getElementById('severity');
        const bountyEstimate = document.getElementById('bountyEstimate');
        const bountyAmount = document.getElementById('bountyAmount');
        const bountyRange = document.getElementById('bountyRange');
        const severityBadge = document.getElementById('severityBadge');

        // Severity matrix data (will be populated from API)
        let severityMatrix = [];

        // Load severity matrix from API
        async function loadSeverityMatrix() {
            try {
                const response = await fetch('/api/severity-matrix');
                const data = await response.json();
                if (data.success) {
                    severityMatrix = data.data;
                }
            } catch (err) {
                console.error('Failed to load severity matrix:', err);
                // Fallback data
                severityMatrix = [
                    { severity: 'critical', cvss_min: 9.0, cvss_max: 10.0, min_bounty: 5000, max_bounty: 20000, color: '#ef4444', icon: '💀' },
                    { severity: 'high', cvss_min: 7.0, cvss_max: 8.9, min_bounty: 1000, max_bounty: 5000, color: '#f97316', icon: '🔥' },
                    { severity: 'medium', cvss_min: 4.0, cvss_max: 6.9, min_bounty: 250, max_bounty: 1000, color: '#eab308', icon: '⚡' },
                    { severity: 'low', cvss_min: 0.1, cvss_max: 3.9, min_bounty: 50, max_bounty: 250, color: '#22c55e', icon: '📝' },
                    { severity: 'info', cvss_min: 0, cvss_max: 0, min_bounty: 0, max_bounty: 0, color: '#3b82f6', icon: 'ℹ️' }
                ];
            }
        }

        // Get bounty range for selected program
        function getBountyRange(severity) {
            const selectedProgram = programSelect.options[programSelect.selectedIndex];
            const matrixData = severityMatrix.find(row => row.severity === severity);
            
            if (!matrixData) return { min: 0, max: 0, estimated: 0 };

            // Check if program has custom ranges
            if (selectedProgram && selectedProgram.value) {
                const minBounty = selectedProgram.getAttribute(`data-${severity}-min`);
                const maxBounty = selectedProgram.getAttribute(`data-${severity}-max`);
                
                if (minBounty && maxBounty && parseFloat(minBounty) > 0) {
                    return {
                        min: parseFloat(minBounty),
                        max: parseFloat(maxBounty),
                        estimated: (parseFloat(minBounty) + parseFloat(maxBounty)) / 2
                    };
                }
            }

            // Fall back to global matrix
            return {
                min: matrixData.min_bounty,
                max: matrixData.max_bounty,
                estimated: (matrixData.min_bounty + matrixData.max_bounty) / 2
            };
        }

        // Update bounty estimate display
        function updateBountyEstimate() {
            const severity = severitySelect.value;
            const programId = programSelect.value;

            if (!severity) {
                bountyEstimate.style.display = 'none';
                return;
            }

            bountyEstimate.style.display = 'block';
            bountyEstimate.classList.add('calculated');

            const range = getBountyRange(severity);
            const matrixData = severityMatrix.find(row => row.severity === severity);

            // Update bounty amount
            if (severity === 'info') {
                bountyAmount.textContent = 'Swag/Points';
                bountyRange.textContent = 'No monetary reward for informational findings';
            } else {
                bountyAmount.textContent = '$' + Math.round(range.estimated).toLocaleString();
                bountyRange.textContent = `Range: $${Math.round(range.min).toLocaleString()} - $${Math.round(range.max).toLocaleString()}`;
            }

            // Update severity badge
            if (matrixData) {
                severityBadge.textContent = matrixData.icon + ' ' + severity.charAt(0).toUpperCase() + severity.slice(1);
                severityBadge.className = 'severity-badge-inline ' + severity;
            }
        }

        // Event listeners for bounty estimate
        programSelect.addEventListener('change', function() {
            updateRewardInfo();
            updateBountyEstimate();
        });

        severitySelect.addEventListener('change', updateBountyEstimate);

        // Initialize
        loadSeverityMatrix();

        // Initialize markdown editors
        const markdownEditors = document.querySelectorAll('.markdown-editor');
        
        markdownEditors.forEach(editor => {
            const tabs = editor.querySelectorAll('.markdown-tab');
            const contents = editor.querySelectorAll('.markdown-tab-content');
            const fieldName = editor.getAttribute('data-field');
            const textarea = editor.querySelector('textarea');
            const preview = editor.querySelector('.markdown-preview');
            
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const tabName = tab.getAttribute('data-tab');
                    
                    // Update active states
                    tabs.forEach(t => t.classList.remove('active'));
                    contents.forEach(c => c.classList.remove('active'));
                    tab.classList.add('active');
                    editor.querySelector(`[data-content="${tabName}"]`).classList.add('active');
                    
                    // If switching to preview, render markdown
                    if (tabName === 'preview') {
                        const markdownText = textarea.value;
                        const html = marked.parse(markdownText || '*Nothing to preview*');
                        preview.innerHTML = html;
                        
                        // Apply syntax highlighting
                        preview.querySelectorAll('pre code').forEach((block) => {
                            hljs.highlightElement(block);
                        });
                    }
                });
            });
            
            // Live update preview when typing (if preview is active)
            textarea.addEventListener('input', () => {
                const previewContent = editor.querySelector('[data-content="preview"]');
                if (previewContent.classList.contains('active')) {
                    const markdownText = textarea.value;
                    const html = marked.parse(markdownText || '*Nothing to preview*');
                    preview.innerHTML = html;
                    preview.querySelectorAll('pre code').forEach((block) => {
                        hljs.highlightElement(block);
                    });
                }
            });
        });

        // File upload handling
        const fileInput = document.getElementById('attachments');
        const dropZone = document.getElementById('dropZone');
        const fileList = document.getElementById('fileList');
        const MAX_FILES = 5;
        const MAX_SIZE = 10 * 1024 * 1024; // 10MB

        const allowedTypes = {
            'image/jpeg': ['.jpg', '.jpeg'],
            'image/png': ['.png'],
            'image/gif': ['.gif'],
            'image/webp': ['.webp'],
            'application/pdf': ['.pdf'],
            'video/mp4': ['.mp4'],
            'video/webm': ['.webm'],
            'video/ogg': ['.ogg'],
            'video/quicktime': ['.mov']
        };

        let selectedFiles = [];

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function validateFile(file) {
            const allowedExts = Object.values(allowedTypes).flat();
            const ext = '.' + file.name.split('.').pop().toLowerCase();
            
            if (!allowedExts.includes(ext)) {
                return `Invalid file type. "${file.name}" is not an allowed file type.`;
            }
            if (file.size > MAX_SIZE) {
                return `File too large. "${file.name}" exceeds 10MB limit.`;
            }
            return null;
        }

        function updateFileList() {
            fileList.innerHTML = '';
            
            if (selectedFiles.length === 0) {
                dropZone.style.display = 'block';
                return;
            }

            dropZone.style.display = selectedFiles.length >= MAX_FILES ? 'none' : 'block';

            selectedFiles.forEach((file, index) => {
                const fileItem = document.createElement('div');
                fileItem.className = 'file-item';
                
                const fileType = file.type.startsWith('image/') ? 'image' : 
                               file.type === 'application/pdf' ? 'pdf' : 'video';
                
                let iconSvg = '';
                if (fileType === 'image') {
                    iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>`;
                } else if (fileType === 'pdf') {
                    iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>`;
                } else {
                    iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>`;
                }
                
                fileItem.innerHTML = `
                    <div class="file-icon">${iconSvg}</div>
                    <div class="file-info">
                        <div class="file-name">${file.name}</div>
                        <div class="file-size">${formatFileSize(file.size)}</div>
                    </div>
                    <button type="button" class="file-remove" data-index="${index}" title="Remove file">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                `;
                
                fileList.appendChild(fileItem);
            });

            // Add event listeners to remove buttons
            document.querySelectorAll('.file-remove').forEach(btn => {
                btn.addEventListener('click', function() {
                    const index = parseInt(this.getAttribute('data-index'));
                    selectedFiles.splice(index, 1);
                    updateFileList();
                    updateFileInput();
                });
            });
        }

        function updateFileInput() {
            const dataTransfer = new DataTransfer();
            selectedFiles.forEach(file => dataTransfer.items.add(file));
            fileInput.files = dataTransfer.files;
        }

        fileInput.addEventListener('change', function(e) {
            const newFiles = Array.from(e.target.files);
            const errors = [];

            newFiles.forEach(file => {
                if (selectedFiles.length >= MAX_FILES) {
                    errors.push(`Cannot add "${file.name}". Maximum ${MAX_FILES} files allowed.`);
                    return;
                }
                
                const error = validateFile(file);
                if (error) {
                    errors.push(error);
                } else {
                    selectedFiles.push(file);
                }
            });

            if (errors.length > 0) {
                const errorDiv = document.createElement('div');
                errorDiv.className = 'file-error';
                errorDiv.innerHTML = errors.join('<br>');
                fileList.insertBefore(errorDiv, fileList.firstChild);
                setTimeout(() => errorDiv.remove(), 5000);
            }

            updateFileList();
            updateFileInput();
        });

        // Drag and drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, function(e) {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, function() {
                dropZone.classList.add('drag-over');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, function() {
                dropZone.classList.remove('drag-over');
            }, false);
        });

        dropZone.addEventListener('drop', function(e) {
            const files = Array.from(e.dataTransfer.files);
            const errors = [];

            files.forEach(file => {
                if (selectedFiles.length >= MAX_FILES) {
                    errors.push(`Cannot add "${file.name}". Maximum ${MAX_FILES} files allowed.`);
                    return;
                }
                
                const error = validateFile(file);
                if (error) {
                    errors.push(error);
                } else {
                    selectedFiles.push(file);
                }
            });

            if (errors.length > 0) {
                const errorDiv = document.createElement('div');
                errorDiv.className = 'file-error';
                errorDiv.innerHTML = errors.join('<br>');
                fileList.insertBefore(errorDiv, fileList.firstChild);
                setTimeout(() => errorDiv.remove(), 5000);
            }

            updateFileList();
            updateFileInput();
        });

        // Form submission - files are already in the input
        document.querySelector('form').addEventListener('submit', function(e) {
            updateFileInput();
        });
    </script>
</body>
