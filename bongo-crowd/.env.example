# Database Configuration
DB_HOST=localhost
DB_NAME=bongocrowd
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# Session Secret (generate strong random string)
SESSION_SECRET=your_very_long_random_string_here_min_32_chars

# Server
PORT=3000
NODE_ENV=production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/auth/google/callback

# Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bongocrowd.com
